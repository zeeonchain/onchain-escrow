# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file — it holds a real wallet private key.

# Alchemy RPC URL for Base Sepolia
# Get one at https://dashboard.alchemy.com -> Create App -> Base Sepolia
ALCHEMY_BASE_SEPOLIA_URL=https://base-sepolia.g.alchemy.com/v2/your-api-key

# Private key of the wallet you'll deploy from (Base Sepolia testnet funds only —
# get free testnet ETH from a Base Sepolia faucet, e.g. https://www.alchemy.com/faucets/base-sepolia)
# Do NOT use a wallet that holds real funds on any network.
PRIVATE_KEY=your-wallet-private-key-without-0x-prefix

# Basescan API key, used to verify the deployed contract's source code.
# Get one at https://basescan.org/myapikey
BASESCAN_API_KEY=your-basescan-api-key
