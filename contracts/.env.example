# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file — it holds a real wallet private key.

# Private key of the wallet you'll deploy from (Monad testnet funds only —
# get free testnet MON from the Monad faucet, e.g.
# https://faucet.monad.xyz/)
# Do NOT use a wallet that holds real funds on any network.
PRIVATE_KEY=your-wallet-private-key-without-0x-prefix