# Copy this file to .env and fill in your own values.

# Alchemy API key (just the key, not the full URL — the app builds the
# Base Sepolia RPC URL from this). Get one at https://dashboard.alchemy.com
VITE_ALCHEMY_API_KEY=your-alchemy-api-key

# WalletConnect Project ID, powers the wallet connection modal (RainbowKit).
# Get one free at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# The deployed Escrow contract address on Base Sepolia.
# Fill this in after running `npm run deploy:baseSepolia` in /contracts.
VITE_CONTRACT_ADDRESS=0x...
